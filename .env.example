# Copy to .env and fill in.
#
# ── Asset generation (tools/) ────────────────────────────────────────────────
# Only needed to REGENERATE assets. The game itself runs without any of these.
GEMINI_API_KEY=        # nano-banana image gen + Veo video
OPENAI_API_KEY=        # GPT Image (stages, UI, portraits)
ELEVENLABS_API_KEY=    # announcer VO + SFX
FAL_KEY=               # fal.ai fallback route for nano-banana / Veo
FISH_API_KEY=          # fish audio voice clone (gen:voice; cloned VO in gen:audio)
CORRIDORKEY_DIR=       # optional: path to the CorridorKey clone (default: ../CorridorKey; gen:key clones it there if missing)

# ── App runtime (VITE_-prefixed = PUBLIC, baked into the client bundle) ───────
# Where the browser loads game media (sprites, audio, 3d, backgrounds) from.
# EMPTY  → same origin (served by Cloudflare Pages). This is the launch default.
# Set it → offload heavy media to R2, e.g.  https://cdn.martiankombat.com/
#          (must end with a trailing slash). Not secret.
VITE_ASSET_BASE=

# ── Deploy + R2 (SECRETS — never commit real values; prefer CI secrets) ───────
# Not needed if you deploy Pages via the dashboard Git integration (recommended).
# Only needed for CLI/CI deploys and for uploading assets to R2.
CLOUDFLARE_ACCOUNT_ID=      # Cloudflare dashboard → Workers & Pages → Account ID
CLOUDFLARE_API_TOKEN=       # token with "Cloudflare Pages:Edit" + "Workers R2 Storage:Edit"

# R2 bucket that holds the heavy/offloaded assets.
R2_BUCKET=martiankombat-assets
# R2 S3-compatible credentials (R2 → Manage R2 API Tokens → Create) — for
# uploading assets with rclone / aws-cli. Distinct from the CLOUDFLARE_API_TOKEN above.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=               # https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
