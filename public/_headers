# Browser cache policy for Cloudflare Workers Static Assets.
# Default is `public, max-age=0, must-revalidate` — the browser stores each file
# but revalidates it on every visit (a 304 round-trip per file). With hundreds
# of asset files that makes repeat visits slower than they should be. These
# rules skip the revalidation.

# Vite-fingerprinted build output (the hash changes whenever the file does) —
# safe to cache forever.
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable
/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

# Game media has stable, NON-hashed URLs, so this can't be `immutable`: a
# regenerated sprite/audio keeps its path, and a cached browser won't see the
# update until the max-age lapses. One week is a good launch balance (fast
# repeat visits; changes propagate within 7 days). Lower it while actively
# regenerating assets, or raise it once they're stable.
/assets/sprites/*
  Cache-Control: public, max-age=604800
/assets/audio/*
  Cache-Control: public, max-age=604800
/assets/backgrounds/*
  Cache-Control: public, max-age=604800
/assets/portraits/*
  Cache-Control: public, max-age=604800
/assets/fatalities/*
  Cache-Control: public, max-age=604800
/assets/vfx/*
  Cache-Control: public, max-age=604800
/assets/ui/*
  Cache-Control: public, max-age=604800
