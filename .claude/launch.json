{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "martian-kombat",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "martian-kombat-mock",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "port": 5173,
      "autoPort": true,
      "env": {
        "MK_CREATOR_MOCK": "1"
      }
    },
    {
      "name": "martian-kombat-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "preview"
      ],
      "port": 4173,
      "autoPort": true
    },
    {
      "name": "martian-kombat-static",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "4180",
        "--directory",
        "dist"
      ],
      "port": 4180,
      "autoPort": true
    }
  ]
}