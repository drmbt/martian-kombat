# Secrets — never commit
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
dist/
.vite/
*.log

# Asset pipeline intermediates. Only the source FRAMES under assets/raw/frames/
# stay versioned — a useful hand-edit point during dev. Everything else under
# assets/raw/ (qa reports/montages, keyed, stages, style-tests, vfx, canonical,
# icons, music, voice-tests, sprite-editor backups) is a regen intermediate and
# is kept OUT of the repo to avoid bloat (regenerate via the gen:* scripts).
assets/raw/*
!assets/raw/frames/
assets/veo-clips/
assets/frame-dumps/
*.mp4.tmp

# Editor
.vscode/
.idea/
*.swp
.lh/

# Python tool cache
__pycache__/
*.pyc